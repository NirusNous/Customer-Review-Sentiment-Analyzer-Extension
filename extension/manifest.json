{
  "manifest_version": 3,
  "name": "Customer Review Sentiment Analyzer",
  "version": "0.1.0",
  "description": "Analyze visible customer reviews on a webpage using a FastAPI AI backend.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyze Reviews"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ]
}